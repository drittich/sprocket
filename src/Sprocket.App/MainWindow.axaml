<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Sprocket.App"
        xmlns:mb="clr-namespace:Sprocket.App.MediaBrowser"
        xmlns:insp="clr-namespace:Sprocket.App.Inspector"
        x:Class="Sprocket.App.MainWindow"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Title="Sprocket"
        Icon="/Assets/sprocket.png"
        Background="{DynamicResource WindowBg}"
        WindowDecorations="BorderOnly">

  <!--
    PLAN.md step 11 — the app UI shell (UI.md §1/§2): a frameless window with custom chrome + inline menu
    bar, splitter-resizable Project / Program / Inspector panes over a full-width Timeline, and a status bar.
    The pane *contents* (media bin, timeline control, inspector) arrive in steps 12–16; this is the structure,
    with the Program monitor + transport + Export + Save + Edit→Undo/Redo fully live.
  -->

  <DockPanel x:Name="Root">

    <!-- ── Title bar: logo · menu · project title/save-state · window controls ─────────────────── -->
    <Border x:Name="TitleBar" DockPanel.Dock="Top" Background="{DynamicResource PanelBg}" Height="34"
            BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto">

        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,6,0" VerticalAlignment="Center">
          <Image Source="/Assets/sprocket.png" Width="22" Height="22" Margin="0,0,8,0"
                 VerticalAlignment="Center" />

          <TextBlock Text="Sprocket" Foreground="{DynamicResource Text}" FontWeight="SemiBold"
                     FontSize="13" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Inline menu bar (UI.md §2): every item bound to its command in MainWindow.WireMenu / WireCommandMenus
             (PLAN.md step 16c). Items whose feature lands in a later step (Sequence, Clip ▸ Enable/Speed,
             Select All) stay visibly disabled rather than silently dead. Accelerators are also handled in
             OnKeyDown (the InputGesture text here is the display label). -->
        <Menu Grid.Column="1" VerticalAlignment="Center" Background="Transparent" Margin="6,0,0,0">
          <MenuItem Header="_File">
            <MenuItem x:Name="NewMenuItem" Header="_New Project" InputGesture="Ctrl+N" />
            <MenuItem x:Name="OpenMenuItem" Header="_Open Project…" InputGesture="Ctrl+O" />
            <MenuItem x:Name="OpenSampleMenuItem" Header="Open Sa_mple Project" />
            <Separator />
            <MenuItem x:Name="SaveMenuItem" Header="_Save Project" InputGesture="Ctrl+S" />
            <MenuItem x:Name="SaveAsMenuItem" Header="Save Project _As…" InputGesture="Ctrl+Shift+S" />
            <Separator />
            <MenuItem x:Name="ImportMenuItem" Header="_Import Media…" InputGesture="Ctrl+I" />
            <MenuItem x:Name="RelinkMenuItem" Header="_Relink Media…" />
            <MenuItem x:Name="ExportMenuItem" Header="_Export…" InputGesture="Ctrl+E" />
            <MenuItem x:Name="ExportQueueMenuItem" Header="Export _Queue…" InputGesture="Ctrl+Shift+E" />
            <MenuItem Header="Export I_nterchange">
              <MenuItem x:Name="ExportEdlMenuItem" Header="_EDL (CMX3600)…" />
              <MenuItem x:Name="ExportFcpXmlMenuItem" Header="_Final Cut XML…" />
            </MenuItem>
            <Separator />
            <MenuItem x:Name="ExitMenuItem" Header="E_xit" InputGesture="Alt+F4" />
          </MenuItem>
          <MenuItem x:Name="EditMenu" Header="_Edit">
            <MenuItem x:Name="UndoMenuItem" Header="_Undo" InputGesture="Ctrl+Z" IsEnabled="False" />
            <MenuItem x:Name="RedoMenuItem" Header="_Redo" InputGesture="Ctrl+Shift+Z" IsEnabled="False" />
            <Separator />
            <MenuItem x:Name="CutMenuItem" Header="Cu_t" InputGesture="Ctrl+X" IsEnabled="False" />
            <MenuItem x:Name="CopyMenuItem" Header="_Copy" InputGesture="Ctrl+C" IsEnabled="False" />
            <MenuItem x:Name="PasteMenuItem" Header="_Paste" InputGesture="Ctrl+V" IsEnabled="False" />
            <MenuItem x:Name="DeleteMenuItem" Header="_Delete" InputGesture="Delete" IsEnabled="False" />
            <MenuItem x:Name="RippleDeleteMenuItem" Header="_Ripple Delete" InputGesture="Shift+Delete" IsEnabled="False" />
            <Separator />
            <!-- Select All needs multi-clip selection (not yet modelled) — stays disabled. -->
            <MenuItem x:Name="SelectAllMenuItem" Header="Select _All" InputGesture="Ctrl+A" IsEnabled="False" />
          </MenuItem>
          <MenuItem x:Name="ClipMenu" Header="_Clip">
            <!-- Insert generators / adjustment layer at the playhead (PLAN.md step 19); children added at runtime. -->
            <MenuItem x:Name="ClipInsertMenuItem" Header="_Insert" />
            <Separator />
            <!-- Per-clip Enable / Speed-Duration aren't modelled yet — visibly disabled. -->
            <MenuItem x:Name="ClipEnableMenuItem" Header="_Enable" IsEnabled="False" />
            <Separator />
            <!-- Link needs a multi-clip selection to group; Unlink works on the selected linked clip. -->
            <MenuItem x:Name="ClipLinkMenuItem" Header="_Link" IsEnabled="False" />
            <MenuItem x:Name="ClipUnlinkMenuItem" Header="_Unlink" IsEnabled="False" />
            <Separator />
            <MenuItem x:Name="ClipSpeedMenuItem" Header="_Speed / Duration…" IsEnabled="False" /> <!-- enabled when a clip is selected -->

            <Separator />
            <!-- Loudness-normalize the selected clip's audio to the mixer's target (PLAN.md step 30); enabled when
                 the selected clip references an audio-bearing source. Applying it to each clip matches their loudness. -->
            <MenuItem x:Name="ClipNormalizeMenuItem" Header="_Normalize Audio" IsEnabled="False" />

            <Separator />
            <!-- Multicam (PLAN.md step 24): build a synced angle group from the stacked video tracks. Switch the
                 active angle with the 1–9 keys or the Inspector. Create enables when ≥2 video tracks carry a clip. -->
            <MenuItem x:Name="CreateMulticamMenuItem" Header="Create _Multicam Source" IsEnabled="False" />

            <Separator />
            <MenuItem x:Name="NudgeLeftMenuItem" Header="Nudge _Left" InputGesture="Alt+Left" IsEnabled="False" />
            <MenuItem x:Name="NudgeRightMenuItem" Header="Nudge _Right" InputGesture="Alt+Right" IsEnabled="False" />
          </MenuItem>
          <!-- Sequences: multiple sequences + nested/compound clips (PLAN.md step 23). New / Open / Settings are
               always available; Nest enables when a clip is selected; Open Sequence lists every sequence (the
               active one checked) and is populated on submenu-open in RefreshSequenceMenu. -->
          <MenuItem x:Name="SequenceMenu" Header="_Sequence">
            <MenuItem x:Name="NewSequenceMenuItem" Header="_New Sequence" />
            <MenuItem x:Name="OpenSequenceMenuItem" Header="_Open Sequence" />
            <Separator />
            <MenuItem x:Name="NestMenuItem" Header="_Nest" IsEnabled="False" />
            <Separator />
            <!-- Preview render cache (PLAN.md step 32): render commands + cache management. Render In to Out
                 uses the timeline in/out marks (I / O keys; Alt+I / Alt+O clear) and falls back to the whole
                 sequence when unset; Delete Render Files shows the cache's disk footprint on submenu-open. -->
            <MenuItem x:Name="RenderInOutMenuItem" Header="_Render In to Out" />
            <MenuItem x:Name="RenderSelectionMenuItem" Header="Render Se_lection" IsEnabled="False" />
            <MenuItem x:Name="RenderAudioMenuItem" Header="Render _Audio" />
            <MenuItem x:Name="DeleteRenderFilesMenuItem" Header="_Delete Render Files…" />
            <Separator />
            <MenuItem x:Name="SequenceSettingsMenuItem" Header="Sequence _Settings…" />
          </MenuItem>
          <!-- Effects menu is populated from EffectCatalog at runtime (WireCommandMenus). -->
          <MenuItem x:Name="EffectsMenu" Header="Effe_cts" />
          <MenuItem x:Name="ViewMenu" Header="_View">
            <!-- Ctrl++/Ctrl+- are handled in OnKeyDown; we don't set InputGesture here because Avalonia would
                 render the OemPlus/OemMinus enum names (e.g. "Ctrl+OemPlus"). The clean shortcut text lives in
                 the timeline zoom buttons' tooltips instead. Shift+Z renders cleanly so it keeps its gesture. -->
            <MenuItem x:Name="ZoomInMenuItem" Header="Zoom _In" />
            <MenuItem x:Name="ZoomOutMenuItem" Header="Zoom _Out" />
            <MenuItem x:Name="ZoomToFitMenuItem" Header="Zoom to _Fit" InputGesture="Shift+Z" />
            <Separator />
            <MenuItem x:Name="SnappingMenuItem" Header="_Snapping" ToggleType="CheckBox" />
            <MenuItem x:Name="GuidesMenuItem" Header="_Guides" ToggleType="CheckBox" />
            <Separator />
            <MenuItem x:Name="ShowProjectMenuItem" Header="_Project Panel" ToggleType="CheckBox" IsChecked="True" />
            <MenuItem x:Name="ShowInspectorMenuItem" Header="I_nspector Panel" ToggleType="CheckBox" IsChecked="True" />
            <Separator />
            <MenuItem x:Name="ShowStatsMenuItem" Header="Playback _Statistics" ToggleType="CheckBox" />
          </MenuItem>
          <MenuItem x:Name="WindowMenu" Header="_Window">
            <MenuItem x:Name="ResetLayoutMenuItem" Header="_Reset Layout" />
          </MenuItem>
          <MenuItem Header="_Help">
            <MenuItem x:Name="AboutMenuItem" Header="_About Sprocket" />
          </MenuItem>
        </Menu>

        <!-- Project title + save state (centered). -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Spacing="8">
          <TextBlock x:Name="ProjectTitleText" Foreground="{DynamicResource Text}" FontSize="12"
                     VerticalAlignment="Center" Text="Untitled" />
          <TextBlock x:Name="SaveStateText" Foreground="{DynamicResource FaintText}" FontSize="12"
                     VerticalAlignment="Center" Text="• all changes saved" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
          <Button x:Name="MinButton" Classes="caption" Content="—"
                  AutomationProperties.Name="Minimize" ToolTip.Tip="Minimize" />
          <!-- MaxButton's glyph + accessible name toggle Maximize/Restore in OnPropertyChanged. -->
          <Button x:Name="MaxButton" Classes="caption" Content="▢"
                  AutomationProperties.Name="Maximize" ToolTip.Tip="Maximize" />
          <Button x:Name="CloseButton" Classes="caption close" Content="✕"
                  AutomationProperties.Name="Close" ToolTip.Tip="Close" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Tool + action bar ───────────────────────────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource WindowBg}" Padding="10,4"
            BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
          <!-- Tool palette (radio group): Select/Blade edit, Ripple/Roll/Slip/Slide trim, Hand/Zoom view
               (PLAN.md steps 13/22, UI.md §3.2). -->
          <RadioButton x:Name="SelectTool" Classes="tool" GroupName="Tools" Content="Select" IsChecked="True"
                       ToolTip.Tip="Select, move, and edge-trim clips" />
          <RadioButton x:Name="BladeTool" Classes="tool" GroupName="Tools" Content="Blade"
                       ToolTip.Tip="Razor: click a clip to split it at the cursor" />
          <RadioButton x:Name="RippleTool" Classes="tool" GroupName="Tools" Content="Ripple"
                       ToolTip.Tip="Ripple edit: trim a clip's edge and shift everything downstream to close the gap" />
          <RadioButton x:Name="RollTool" Classes="tool" GroupName="Tools" Content="Roll"
                       ToolTip.Tip="Rolling edit: drag the cut between two adjacent clips, keeping their combined length" />
          <RadioButton x:Name="SlipTool" Classes="tool" GroupName="Tools" Content="Slip"
                       ToolTip.Tip="Slip a clip's source in/out without moving it on the timeline" />
          <RadioButton x:Name="SlideTool" Classes="tool" GroupName="Tools" Content="Slide"
                       ToolTip.Tip="Slide a clip along the timeline while its neighbours absorb the change" />
          <RadioButton x:Name="HandTool" Classes="tool" GroupName="Tools" Content="Hand"
                       ToolTip.Tip="Pan the timeline view" />
          <RadioButton x:Name="ZoomTool" Classes="tool" GroupName="Tools" Content="Zoom"
                       ToolTip.Tip="Zoom the timeline view (click to zoom in, Alt-click to zoom out)" />
          <Border Width="1" Height="18" Background="{DynamicResource Edge}" Margin="8,0" />
          <ToggleButton x:Name="SnappingToggle" Content="Snapping" IsChecked="True" FontSize="12" Padding="8,3"
                        ToolTip.Tip="Snap clip edges and the playhead to nearby edits, markers, and the playhead while dragging" />
          <ToggleButton x:Name="LinkedToggle" Content="Linked" IsChecked="True" FontSize="12" Padding="8,3" Margin="2,0,0,0"
                        ToolTip.Tip="Move linked audio and video clips together as a group when editing" />
        </StackPanel>

        <TextBlock x:Name="SequenceBadge" Grid.Column="2" Margin="0,0,12,0" VerticalAlignment="Center"
                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"
                   Foreground="{DynamicResource MutedText}" Text="—" />
        <Button x:Name="ExportButton" Grid.Column="3" Classes="primary" Content="Export" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- ── Status bar (bottom) ─────────────────────────────────────────────────────────────────── -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBg}" Height="26"
            BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
        <!-- Live engine state + GPU/hardware-accel status (UI.md §3.7); driven by UpdateEngineStatus(). The
             initial values here are just the parked state before the transport is wired. -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
          <Ellipse x:Name="StateDot" Width="8" Height="8" Fill="{DynamicResource Good}" VerticalAlignment="Center" />
          <TextBlock x:Name="EngineStateText" Foreground="{DynamicResource MutedText}" FontSize="11"
                     VerticalAlignment="Center" Text="Ready" />
        </StackPanel>
        <!-- Media info / transient messages (export + save status). -->
        <TextBlock x:Name="StatusText" Grid.Column="1" Margin="16,0" VerticalAlignment="Center"
                   Foreground="{DynamicResource FaintText}" FontSize="11" TextTrimming="CharacterEllipsis" Text="" />
        <!-- Live telemetry: (measured while playing, else nominal) fps · resolution · duration. NO framework/
             runtime text (UI.md §3.7). Polled at 1 Hz only during playback — see the perf note in the code-behind. -->
        <TextBlock x:Name="TelemetryText" Grid.Column="2" VerticalAlignment="Center"
                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="11"
                   Foreground="{DynamicResource MutedText}" Text="" />
      </Grid>
    </Border>

    <!-- ── Workspace: Project | Program | Inspector  over  Timeline (all splitter-resizable) ─────── -->
    <Grid x:Name="OuterGrid" Margin="6" RowDefinitions="*,6,240">

      <Grid x:Name="WorkspaceGrid" Grid.Row="0" ColumnDefinitions="240,6,*,6,300">

        <!-- Project panel: tabbed media bin / effects / transitions / audio browser (PLAN.md step 15). -->
        <Border x:Name="ProjectPane" Grid.Column="0" Classes="pane">
          <DockPanel>
            <Border DockPanel.Dock="Top" Classes="paneHeader">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Classes="title" Text="Project" />
                <TextBlock x:Name="ProjectItemsText" Grid.Column="1" HorizontalAlignment="Right"
                           Foreground="{DynamicResource FaintText}" FontSize="11" VerticalAlignment="Center"
                           Text="0 items" />
              </Grid>
            </Border>
            <mb:MediaBrowserPanel x:Name="MediaBrowser" />
          </DockPanel>
        </Border>

        <GridSplitter x:Name="ProjectSplitter" Grid.Column="1" Width="6" Background="Transparent" ResizeDirection="Columns"
                      HorizontalAlignment="Stretch" />

        <!-- Program monitor: the live preview + transport. -->
        <Border Grid.Column="2" Classes="pane" ClipToBounds="True">
          <DockPanel>
            <Border DockPanel.Dock="Top" Classes="paneHeader">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Dual-monitor tabs: Program (composited timeline) / Source (raw clip), UI.md §3.4. -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <RadioButton x:Name="ProgramTab" Classes="tool" GroupName="Monitor" Content="Program" IsChecked="True" />
                  <RadioButton x:Name="SourceTab" Classes="tool" GroupName="Monitor" Content="Source" />
                </StackPanel>
                <!-- Grading scopes selector (PLAN.md step 34) + safe-area / framing-grid overlay toggle +
                     the Fit ▾ zoom level. -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <ComboBox x:Name="ScopeBox" MinWidth="112" FontSize="12" SelectedIndex="0">
                    <ComboBoxItem>No Scopes</ComboBoxItem>
                    <ComboBoxItem>Waveform</ComboBoxItem>
                    <ComboBoxItem>RGB Parade</ComboBoxItem>
                    <ComboBoxItem>Vectorscope</ComboBoxItem>
                    <ComboBoxItem>Histogram</ComboBoxItem>
                  </ComboBox>
                  <ToggleButton x:Name="GuidesToggle" Content="Guides" FontSize="12" Padding="8,3" />
                  <ComboBox x:Name="ZoomBox" MinWidth="76" FontSize="12" SelectedIndex="0">
                    <ComboBoxItem>Fit</ComboBoxItem>
                    <ComboBoxItem>50%</ComboBoxItem>
                    <ComboBoxItem>100%</ComboBoxItem>
                    <ComboBoxItem>200%</ComboBoxItem>
                  </ComboBox>
                </StackPanel>
              </Grid>
            </Border>

            <!-- Transport (under the monitor, UI.md §3.4). -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBg}" Padding="10,5"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0">
              <!-- Full transport (UI.md §3.4): ⏮ ◀◀ ▶ ▶▶ ⏭ — jump-to-start, frame-step back, play/pause,
                   frame-step forward, jump-to-end — plus jump-to-previous/next-keyframe (◆◀ ▶◆, PLAN.md
                   step 16d). Drives whichever monitor (Program/Source) is active. -->
              <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" VerticalAlignment="Center">
                <Button x:Name="JumpStartButton" Grid.Column="0" Classes="transport" Content="⏮"
                        AutomationProperties.Name="Jump to start" ToolTip.Tip="Jump to start" />
                <Button x:Name="StepBackButton" Grid.Column="1" Classes="transport" Content="◀◀" Margin="4,0,0,0"
                        AutomationProperties.Name="Step back one frame" ToolTip.Tip="Step back one frame" />
                <!-- PlayPauseButton's glyph + accessible name toggle Play/Pause as playback state changes. -->
                <Button x:Name="PlayPauseButton" Grid.Column="2" Classes="transport play" Content="▶" Margin="4,0,0,0"
                        AutomationProperties.Name="Play" ToolTip.Tip="Play / Pause (Space)" />
                <Button x:Name="StepForwardButton" Grid.Column="3" Classes="transport" Content="▶▶" Margin="4,0,0,0"
                        AutomationProperties.Name="Step forward one frame" ToolTip.Tip="Step forward one frame" />
                <Button x:Name="JumpEndButton" Grid.Column="4" Classes="transport" Content="⏭" Margin="4,0,0,0"
                        AutomationProperties.Name="Jump to end" ToolTip.Tip="Jump to end" />
                <Button x:Name="PrevKeyframeButton" Grid.Column="5" Classes="transport" Content="◆◀" Margin="12,0,0,0"
                        AutomationProperties.Name="Previous keyframe"
                        ToolTip.Tip="Jump to previous keyframe of the selected clip — press [" />
                <Button x:Name="NextKeyframeButton" Grid.Column="6" Classes="transport" Content="▶◆" Margin="4,0,0,0"
                        AutomationProperties.Name="Next keyframe"
                        ToolTip.Tip="Jump to next keyframe of the selected clip — press ]" />
                <TextBlock x:Name="PositionText" Grid.Column="7" Margin="14,0,10,0" VerticalAlignment="Center"
                           FontFamily="Cascadia Code,Consolas,monospace" Foreground="{DynamicResource Text}"
                           Text="0:00.00" />
                <Slider x:Name="Scrubber" Grid.Column="8" Minimum="0" Maximum="1" Value="0" VerticalAlignment="Center">
                  <!-- Match the themed transport: accent-tint the played (value) portion, and let the thumb read
                       as the accent on interaction. Overrides the Fluent Slider theme brushes in the control's
                       own scope (keys verified present in the Avalonia 12.0.5 Fluent theme). -->
                  <Slider.Resources>
                    <SolidColorBrush x:Key="SliderTrackValueFill" Color="{x:Static local:Palette.Accent}" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{x:Static local:Palette.Accent}" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{x:Static local:Palette.AccentHover}" />
                    <SolidColorBrush x:Key="SliderThumbBackground" Color="{x:Static local:Palette.Text}" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="{x:Static local:Palette.Accent}" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="{x:Static local:Palette.AccentHover}" />
                  </Slider.Resources>
                </Slider>
                <TextBlock x:Name="DurationText" Grid.Column="9" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="Cascadia Code,Consolas,monospace" Foreground="{DynamicResource MutedText}"
                           Text="0:00.00" />
              </Grid>
            </Border>

            <!-- Grading scopes (PLAN.md step 34): waveform / RGB parade / vectorscope / histogram of the
                 monitor composite, shown under the picture when a scope is selected in the header. -->
            <Border x:Name="ScopeHost" DockPanel.Dock="Bottom" Height="170" IsVisible="False"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0">
              <local:ScopeView x:Name="ScopePanel" />
            </Border>

            <!-- Both monitors (Program/Source) present through this one surface; the active tab swaps the
                 engine it is attached to (PLAN.md step 17). -->
            <local:PreviewSurface x:Name="Preview" />
          </DockPanel>
        </Border>

        <GridSplitter x:Name="InspectorSplitter" Grid.Column="3" Width="6" Background="Transparent" ResizeDirection="Columns"
                      HorizontalAlignment="Stretch" />

        <!-- Inspector: type-driven, collapsible property sections for the selected clip (PLAN.md step 16). -->
        <Border x:Name="InspectorPane" Grid.Column="4" Classes="pane">
          <DockPanel>
            <Border DockPanel.Dock="Top" Classes="paneHeader">
              <TextBlock Classes="title" Text="Inspector" />
            </Border>
            <insp:InspectorPanel x:Name="Inspector" />
          </DockPanel>
        </Border>
      </Grid>

      <GridSplitter Grid.Row="1" Height="6" Background="Transparent" ResizeDirection="Rows"
                    HorizontalAlignment="Stretch" VerticalAlignment="Center" />

      <!-- Timeline (custom-drawn control lands in step 12). -->
      <Border Grid.Row="2" Classes="pane">
        <DockPanel>
          <Border DockPanel.Dock="Top" Classes="paneHeader">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
              <TextBlock x:Name="TimelineHeader" Classes="title" Text="Timeline" />
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                          Margin="0,0,10,0">
                <Button x:Name="ZoomOutButton" Padding="6,3" VerticalAlignment="Center"
                        AutomationProperties.Name="Zoom out" ToolTip.Tip="Zoom Out (Ctrl+-)">
                  <Path Data="M12,7 A5,5 0 1,1 2,7 A5,5 0 1,1 12,7 M10.9,10.9 L15,15 M4,7 L10,7"
                        Stroke="{DynamicResource MutedText}" StrokeThickness="1.4"
                        StrokeLineCap="Round" Width="16" Height="16" Stretch="None" />
                </Button>
                <Button x:Name="ZoomInButton" Padding="6,3" VerticalAlignment="Center"
                        AutomationProperties.Name="Zoom in" ToolTip.Tip="Zoom In (Ctrl+=)">
                  <Path Data="M12,7 A5,5 0 1,1 2,7 A5,5 0 1,1 12,7 M10.9,10.9 L15,15 M4,7 L10,7 M7,4 L7,10"
                        Stroke="{DynamicResource MutedText}" StrokeThickness="1.4"
                        StrokeLineCap="Round" Width="16" Height="16" Stretch="None" />
                </Button>
              </StackPanel>
              <Button x:Name="MarkersButton" Grid.Column="3" Content="Markers" FontSize="12" Padding="10,3"
                      Margin="0,0,6,0" VerticalAlignment="Center"
                      ToolTip.Tip="Markers panel (M adds at the playhead; Shift+M / Ctrl+Shift+M navigate)" />
              <Button x:Name="AddTrackButton" Grid.Column="4" Content="+ Track" FontSize="12" Padding="10,3"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>
          <!-- The timeline is custom-drawn and can't host children, so the inline track-rename editor is
               overlaid here, sharing the timeline's (0,0) origin; it is positioned/shown from code-behind. -->
          <Panel>
            <local:TimelineControl x:Name="Timeline" />
            <TextBox x:Name="TrackRenameEditor" IsVisible="False"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     FontSize="11.5" Padding="2,1" MinHeight="0" />
          </Panel>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
