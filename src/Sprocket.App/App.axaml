<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Sprocket.App"
             x:Class="Sprocket.App.App"
             RequestedThemeVariant="Dark">
  <Application.Resources>
    <!-- Palette (UI.md §1): near-black surfaces + a single indigo/violet accent. All values come from the
         Palette class (Palette.cs) so the shell and the custom-drawn Skia surfaces share one source. -->
    <SolidColorBrush x:Key="WindowBg" Color="{x:Static app:Palette.WindowBg}" />
    <SolidColorBrush x:Key="PanelBg" Color="{x:Static app:Palette.PanelBg}" />
    <SolidColorBrush x:Key="RaisedBg" Color="{x:Static app:Palette.RaisedBg}" />
    <SolidColorBrush x:Key="Edge" Color="{x:Static app:Palette.Edge}" />
    <SolidColorBrush x:Key="Text" Color="{x:Static app:Palette.Text}" />
    <SolidColorBrush x:Key="MutedText" Color="{x:Static app:Palette.MutedText}" />
    <SolidColorBrush x:Key="FaintText" Color="{x:Static app:Palette.FaintText}" />
    <SolidColorBrush x:Key="Accent" Color="{x:Static app:Palette.Accent}" />
    <SolidColorBrush x:Key="AccentHover" Color="{x:Static app:Palette.AccentHover}" />
    <SolidColorBrush x:Key="Danger" Color="{x:Static app:Palette.Danger}" />

    <!-- Semantic status (status-bar dot; playback-stats health). -->
    <SolidColorBrush x:Key="Good" Color="{x:Static app:Palette.Good}" />
    <SolidColorBrush x:Key="Warn" Color="{x:Static app:Palette.Warn}" />
    <SolidColorBrush x:Key="Bad" Color="{x:Static app:Palette.Bad}" />

    <!-- Compact Fluent control metrics (space-at-a-premium density): smaller radio bullets and slider
         thumb than the Fluent defaults (20px). All RadioButtons in the shell are the tool/monitor palette. -->
    <x:Double x:Key="RadioButtonMinHeight">22</x:Double>
    <x:Double x:Key="SliderHorizontalThumbWidth">14</x:Double>
    <x:Double x:Key="SliderHorizontalThumbHeight">14</x:Double>
    <CornerRadius x:Key="SliderThumbCornerRadius">7</CornerRadius>

    <!-- Placeholder text must clear WCAG AA (≥4.5:1) on the dark input surface — Fluent's default is too dim. -->
    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{x:Static app:Palette.FaintText}" />
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <!-- Shell styling (PLAN.md step 11 / UI.md §1): dark near-black panels, a single indigo accent. -->

    <!-- Titled pane container. -->
    <Style Selector="Border.pane">
      <Setter Property="Background" Value="{DynamicResource PanelBg}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Edge}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- Pane title strip. -->
    <Style Selector="Border.paneHeader">
      <Setter Property="Background" Value="{DynamicResource RaisedBg}" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="BorderBrush" Value="{DynamicResource Edge}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style Selector="TextBlock.title">
      <Setter Property="Foreground" Value="{DynamicResource Text}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Placeholder text for panes whose content lands in a later step. -->
    <Style Selector="TextBlock.placeholder">
      <Setter Property="Foreground" Value="{DynamicResource FaintText}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- Window caption buttons (min / max / close). -->
    <Style Selector="Button.caption">
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.caption:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource RaisedBg}" />
      <Setter Property="Foreground" Value="{DynamicResource Text}" />
    </Style>
    <Style Selector="Button.close:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource Danger}" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Primary action button (Export). -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource Accent}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="Height" Value="26" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentHover}" />
    </Style>

    <!-- Tool-palette radio buttons (Select / Blade / Slip / Hand / Zoom): the checked one shows white. -->
    <Style Selector="RadioButton.tool">
      <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="RadioButton.tool:checked">
      <Setter Property="Foreground" Value="White" />
    </Style>
    <!-- Shrink the Fluent radio bullet (default 20px) to suit the compact toolbar. -->
    <Style Selector="RadioButton.tool /template/ Ellipse#OuterEllipse">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
    </Style>
    <Style Selector="RadioButton.tool /template/ Ellipse#CheckOuterEllipse">
      <Setter Property="Width" Value="15" />
      <Setter Property="Height" Value="15" />
    </Style>
    <Style Selector="RadioButton.tool /template/ Ellipse#CheckGlyph">
      <Setter Property="Width" Value="6" />
      <Setter Property="Height" Value="6" />
    </Style>

    <!-- Transport buttons under the program monitor. -->
    <Style Selector="Button.transport">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource RaisedBg}" />
      <Setter Property="Foreground" Value="{DynamicResource Text}" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <!-- Play/Pause is the primary transport control — carry the accent so it reads as primary. -->
    <Style Selector="Button.transport.play">
      <Setter Property="Background" Value="{DynamicResource Accent}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.transport.play:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentHover}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.transport.play:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource Accent}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
  </Application.Styles>
</Application>
